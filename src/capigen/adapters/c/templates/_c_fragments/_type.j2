{% from "_c_fragments/_format.j2" import format_c_type %}

{%- macro render_type(t) -%}
  {%- if t.description %}//! {{ t.description | c_line_comment }}
{% endif -%}
  {%- if t.tagged_struct -%}
typedef struct _{{ t.name }} {
	void *internal_ptr;
} * {{ t.canonical_name }};
  {%- elif t.is_pointer -%}
typedef {{ format_c_type(t.base) }}* {{ t.canonical_name }};
  {%- elif t.is_qualified -%}
#ifndef DUCKDB_TYPEDEF_{{ t.canonical_name | upper }}
#define DUCKDB_TYPEDEF_{{ t.canonical_name | upper }}
typedef {{ format_c_type(t.base) }} {{ t.canonical_name }};
#endif
  {%- else -%}
typedef {{ format_c_type(t.base) }} {{ t.canonical_name }};
  {%- endif -%}
{%- endmacro %}
