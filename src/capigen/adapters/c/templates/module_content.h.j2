{% from "macros/parameters.j2" import c_function %}
{% from "_c_fragments/funcptr.j2" import render_funcptr %}
{% from "_c_fragments/_struct.j2" import render_struct %}
{% from "_c_fragments/_type.j2" import render_type %}

/* --- Types for {{ module.name }} --- */
{% for type in module.types %}
{{ render_type(type) }}
{% endfor %}

/* --- Enums for {{ module.name }} --- */
{% for enum in module.enums %}
typedef enum {{ enum.name }} {
  {% for value_name, value in enum.values.items() %}
  {% if value.description %}/* {{ value.description }} */
  {% endif %}
  {{ value_name }} = {{ value.value }},
  {% endfor %}
} {{ enum.name }};
{% endfor %}

/* --- Structs for {{ module.name }} --- */
{% for s in module.structs %}
{{ render_struct(s) }}
{% endfor %}

/* --- Constants for {{ module.name }} --- */
{% for const in module.constants %}
#define {{ const.name }} {{ const.value }}
{% endfor %}

/* --- Error Codes for {{ module.name }} --- */
{% for group in module.error_groups %}
{% for entry in group.entries %}
#define {{ entry.name }} (({{ group.group_id }} << 16) | {{ entry.code }})
{% endfor %}
{% endfor %}

/* --- Function pointer typedefs for {{ module.name }} --- */
{% for fp in module.function_ptrs %}
{{ render_funcptr(fp) }}
{% endfor %}

/* --- Functions for {{ module.name }} --- */
{% for func_name, func in module.functions.items() %}
  {%- if func.summary or func.description -%}
/*!
* {{ func.summary }}
    {% if func.description %}
* {{ func.description }}
    {% endif %}
    {% for param_name, param in func.parameters.items() %}
* @param {{ param_name }} {{ param.description or '' }}
    {% endfor %}
* @return {{ func.return_c }}
*/
  {% endif %}
DUCKDB_C_API {% if func.deprecated -%}DUCKDB_DEPRECATED {% endif %}
{{ func.return_c }} {{ func_name }}(
      {%- for name, param in func.parameters.items() -%}
      {{ c_function(name, param) }}{{ ", " if not loop.last }}
      {%- endfor -%}
  );
{% endfor %}
